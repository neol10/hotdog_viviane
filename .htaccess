# Configuração básica para hospedar este app em subpasta (ex: /agenciadaspizzas)
# Foco: PWA/Service Worker e cache previsível

# Evita cache agressivo do service worker (senão atualizações demoram)
<IfModule mod_headers.c>
  <Files "sw.js">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </Files>
</IfModule>

# HTML e manifest devem refletir mudanças rapidamente
<IfModule mod_headers.c>
  <FilesMatch "\.(html|json)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# Assets estáticos podem ter cache forte
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|jpg|jpeg|png|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# (Opcional) Alguns servidores precisam disso para o manifest
AddType application/manifest+json .webmanifest
